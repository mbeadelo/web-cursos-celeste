// Prisma schema — web-cursos-celeste
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
}

enum LessonType {
  VIDEO
  PDF
  TEXT
}

enum EnrollmentSource {
  PURCHASE
  MANUAL
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum CourseBadge {
  BESTSELLER
  NEW
  COMING_SOON
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  enrollments Enrollment[]
  orders      Order[]
  articles    Article[]
  progress    LessonProgress[]
  reviews     Review[]
  // Auth.js relations
  accounts    Account[]
  sessions    Session[]
}

model Course {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  description    String       @db.Text
  priceCents     Int
  currency       String       @default("eur")
  published      Boolean      @default(false)
  coverUrl       String?
  // Optional manual marketing badge shown on cards and the landing page.
  // Manual on purpose: with a small catalogue an automatic "best seller"
  // (e.g. by sales count) can be empty or unfair the first weeks.
  badge          CourseBadge?
  // Optional sort key for /cursos and home — lower numbers come first,
  // ties fall back to createdAt desc. NULL means "no manual order, sort
  // by recency". Lets the admin pin courses without touching dates.
  featuredOrder  Int?
  // Landing copy (optional). Each field is plain text where every non-empty
  // line renders as a bullet on the course landing. Kept as Text (not a
  // relation) — it's rarely >5-8 bullets and the admin form stays trivial.
  targetAudience String?      @db.Text
  whatYouLearn   String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lessons     Lesson[]
  enrollments Enrollment[]
  orders      Order[]
  reviews     Review[]
}

model Lesson {
  id            String     @id @default(cuid())
  courseId      String
  course        Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order         Int
  title         String
  type          LessonType
  // VIDEO: Mux ids. uploadId is the Direct Upload reference (set when admin
  // requests an upload URL); assetId + playbackId are filled by Mux webhooks
  // once the asset finishes processing.
  muxUploadId   String?    @unique
  muxAssetId    String?
  muxPlaybackId String?
  // PDF: object key in R2/S3
  fileKey       String?
  // TEXT: markdown body
  body          String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  progress LessonProgress[]

  @@unique([courseId, order])
  @@index([courseId])
}

model Enrollment {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  source    EnrollmentSource
  createdAt DateTime         @default(now())

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Order {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  courseId              String
  course                Course      @relation(fields: [courseId], references: [id], onDelete: Restrict)
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?     @unique
  status                OrderStatus @default(PENDING)
  amountCents           Int
  currency              String      @default("eur")
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([userId])
}

// Idempotency log for Stripe webhooks. Insert before processing; unique
// constraint prevents double-processing of redelivered events.
model StripeEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())
}

// Long-form articles for SEO and content marketing. Body is sanitized HTML
// produced by the TipTap editor; render server-side via dangerouslySetInnerHTML
// after the sanitizer in lib/html.ts has stripped unsafe nodes/attrs.
model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String    @db.Text
  body        String    @db.Text
  coverUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    String?
  author      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
}

// Editable site copy. Key uses dot notation (e.g. "home.hero.title").
// The app reads via getContent() with a default fallback so missing keys
// don't break the UI; admin can edit via /admin/contenido.
model SiteContent {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// Legal documents (privacidad, terminos, cookies). Slug is fixed by the
// LEGAL_SLUGS list in lib/legal.ts. Body is HTML (TipTap). If a row is
// missing, the public route serves a default template from lib/legal.ts.
model LegalDocument {
  slug      String   @id
  title     String
  body      String   @db.Text
  updatedAt DateTime @updatedAt
}

// Per-student lesson progress. One row per (user, lesson). `lastSeconds` is
// the playhead position in VIDEO lessons (used by "continue where you left
// off"); `completedAt` is set once the student crosses the completion
// threshold (95% for video, explicit click for PDF/TEXT). Keeping the row
// small lets us upsert frequently without table bloat.
model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lastSeconds Int       @default(0)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

// Course reviews. Only users with an Enrollment for the course can submit
// (enforced in server action, not at the schema level). Status starts as
// PENDING and an admin moderates from /admin/reviews. Public landing only
// shows APPROVED rows.
model Review {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rating    Int
  body      String       @db.Text
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([userId, courseId])
  @@index([courseId, status])
}

// ─── Auth.js (NextAuth v5) tables ───
// https://authjs.dev/getting-started/adapters/prisma

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
