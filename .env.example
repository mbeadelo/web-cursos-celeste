# ─── Database (Postgres) ───
# Local dev: Prisma Postgres (`pnpm exec prisma dev`) or Neon/Supabase URL
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ─── Auth.js (NextAuth v5) ───
# Generate with: openssl rand -base64 32 (or `npx auth secret`)
AUTH_SECRET=""
# Only required when deployed behind a proxy on a non-default port
# AUTH_URL="https://your-domain.com"

# ─── Email (Resend) ───
# https://resend.com/api-keys
RESEND_API_KEY=""
# Sin dominio verificado: usa "Bienvenido a tu plaza <onboarding@resend.dev>"
# Con dominio verificado: usa "Bienvenido a tu plaza <noreply@bienvenidoatuplaza.com>"
EMAIL_FROM="Bienvenido a tu plaza <onboarding@resend.dev>"

# ─── Bootstrap admin ───
# Email del primer usuario admin. El seed (pnpm db:seed) lo upsertea con role=ADMIN.
ADMIN_EMAIL=""

# ─── Stripe ───
# Test keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# In production, from the webhook endpoint signing secret in the dashboard.
STRIPE_WEBHOOK_SECRET=""

# ─── Mux (video) ───
# https://dashboard.mux.com/settings/access-tokens
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""
# Signing key for protected playback URLs (create in Mux dashboard)
MUX_SIGNING_KEY_ID=""
MUX_SIGNING_PRIVATE_KEY=""

# ─── Cloudflare R2 (PDFs / static assets) ───
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Optional: custom R2 public domain for unsigned reads (covers, etc.)
R2_PUBLIC_URL=""
